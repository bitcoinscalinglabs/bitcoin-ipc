# Bitcoin Core RPC
RPC_USER=user
RPC_PASS=pass
RPC_URL=http://127.0.0.1:18443
WALLET_NAME=validator2

# Validator
VALIDATOR_SK_PATH=$HOME/.ipc/validator2/validator.sk

# Provider + Monitor
DATABASE_URL=$HOME/.ipc/validator2/regtest_db

# Provider
PROVIDER_PORT=3031
PROVIDER_AUTH_TOKEN=validator2_auth_token

# General
RUST_LOG=bitcoin_ipc=debug,monitor=info,provider=debug,bitcoincore_rpc=error,actix_web=error
