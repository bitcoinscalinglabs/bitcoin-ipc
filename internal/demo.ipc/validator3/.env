# Bitcoin Core RPC
RPC_USER=user
RPC_PASS=pass
RPC_URL=http://localhost:18443
WALLET_NAME=validator3

# Validator
VALIDATOR_SK_PATH=$HOME/.ipc/validator3/validator.sk

# Provider + Monitor
DATABASE_URL=$HOME/.ipc/validator3/regtest_db

# Provider
PROVIDER_PORT=3032
PROVIDER_AUTH_TOKEN=validator3_auth_token

# General
RUST_LOG=bitcoin_ipc=debug,monitor=info,provider=debug,bitcoincore_rpc=error,actix_web=error
