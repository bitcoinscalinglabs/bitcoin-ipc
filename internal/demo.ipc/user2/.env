# Bitcoin Core RPC
RPC_USER=user
RPC_PASS=pass
RPC_URL=http://127.0.0.1:18443
WALLET_NAME=user2

# Validator
# VALIDATOR_SK_PATH=

# Provider + Monitor
DATABASE_URL=$HOME/.ipc/user2/regtest_db

# Provider
PROVIDER_PORT=3041
PROVIDER_AUTH_TOKEN=user2_auth_token

# General
RUST_LOG=bitcoin_ipc=trace,monitor=debug,provider=debug,bitcoincore_rpc=error,actix_web=info

# Reward variables for Emission Chain

ACTIVATION_HEIGHT=0
SNAPSHOT_LENGTH=10
