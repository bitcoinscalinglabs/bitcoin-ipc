# Bitcoin Core RPC
RPC_USER=ristic
RPC_PASS=ristic
RPC_URL=http://localhost:18443
WALLET_NAME=validator6

# Validator
VALIDATOR_SK_PATH=$HOME/.ipc/validator6/validator.sk

# Provider + Monitor
DATABASE_URL=$HOME/.ipc/validator6/regtest_db

# Provider
PROVIDER_PORT=3035
PROVIDER_AUTH_TOKEN=validator6_auth_token

# General
RUST_LOG=bitcoin_ipc=debug,monitor=info,provider=debug,bitcoincore_rpc=error,actix_web=error
