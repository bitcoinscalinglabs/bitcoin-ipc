# Bitcoin Core RPC

RPC_USER=user
RPC_PASS=pass
RPC_URL=http://localhost:18443
WALLET_NAME=validator1

# Validator

VALIDATOR_SK_PATH=/Users/user/.ipc/validator1/validator.sk


# Provider + Monitor

DATABASE_URL=<HOME_DIR>/.ipc/validator1/regtest_db

# Monitor

MONITOR_POLL_INTERVAL=2

# Provider

PROVIDER_PORT=3030
PROVIDER_AUTH_TOKEN=validator1_auth_token
VALIDATOR_SK_PATH=<HOME_DIR>/.ipc/validator1/validator.sk

# General

RUST_LOG=bitcoin_ipc=debug,monitor=debug,provider=debug,bitcoincore_rpc=error,actix_web=info
