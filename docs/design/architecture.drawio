        <mxCell id="7knJM6DkiD1VyGRECrS--22" value="third party" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="1190" y="535" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="7knJM6DkiD1VyGRECrS--31" value="&lt;font style=&quot;font-size: 11px;&quot;&gt;It contains all IPC-subnet logic (Gateway actor) for handling incoming messages and creating outward messages, such as MintDeposited(), Withdraw().&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;In &lt;b&gt;Stage 1&lt;/b&gt;&amp;nbsp;this is instantiated by a Simulator, which is a mock implementation that handles/creates the required messages.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;In &lt;b&gt;Stage 2&lt;/b&gt; this will be Fendermint.&lt;/font&gt;&lt;/div&gt;" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#666600;" parent="1" vertex="1">
          <mxGeometry x="1380" y="410" width="190" height="200" as="geometry" />
        </mxCell>
        <mxCell id="7knJM6DkiD1VyGRECrS--32" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryPerimeter=0;dashed=1;" parent="1" source="7knJM6DkiD1VyGRECrS--3" target="7knJM6DkiD1VyGRECrS--31" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="7knJM6DkiD1VyGRECrS--33" value="&lt;div&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;It monitors the IPC subnet for outgoing transactions (such as t&lt;i&gt;ransfer()&lt;/i&gt;)&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: initial; font-size: 11px;&quot;&gt;and&lt;/span&gt;&lt;span style=&quot;background-color: initial; font-size: 11px;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: initial; font-size: 11px;&quot;&gt;notifies the orchestration layer upon such events.&lt;/span&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#666600;" parent="1" vertex="1">
          <mxGeometry x="1380" y="325" width="190" height="70" as="geometry" />
        </mxCell>
        <mxCell id="7knJM6DkiD1VyGRECrS--35" value="&lt;div&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;Scripts responsible for orchestrating the demo.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;(1) Interact with the IPC Layer Manager&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 11px; background-color: initial;&quot;&gt;(2) Relay messages between L1 (bitcoin) and L2 (IPC subnet).&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 11px;&quot;&gt;* The scripts directly submit transactions to the L2 validator, no need for a dedicated library.&lt;/span&gt;&lt;/div&gt;" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#666600;" parent="1" vertex="1">
          <mxGeometry x="920" y="180" width="400" height="90" as="geometry" />
