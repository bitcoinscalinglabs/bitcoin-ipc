        <mxCell id="7knJM6DkiD1VyGRECrS--20" value="CP team" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="993.5" y="536" width="60" height="30" as="geometry" />
