        <mxCell id="tgi2q5tbjGthcWReG4RT-88" value="&lt;div style=&quot;font-size: 11px;&quot;&gt;&lt;div&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;- Responsible for calling checkpoint() on the subnet and submitting the checkpoint it to the parent.&lt;/span&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;- Monitors the subnet for commands such as transfer() and forwards them to L1.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;- Reads from all subnet validators.&lt;span style=&quot;background-color: initial;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="shape=note;strokeWidth=2;fontSize=14;size=20;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#666600;" parent="1" vertex="1">
