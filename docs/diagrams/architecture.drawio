        <mxCell id="rUX7LjXCXM_KjE6oEwl8-15" value="&lt;span style=&quot;font-size: 10px; text-wrap: wrap;&quot;&gt;RPC&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
